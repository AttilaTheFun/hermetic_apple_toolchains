# Resolve Xcode versions through the hermetic Xcodes instead of locally
# installed ones. Both the native flag and its Starlark counterpart must be
# set while apple_support's migration off the native apple fragment is in
# progress: rules read whichever one is active for the current Bazel version,
# but both are analyzed.
build --xcode_version_config=@apple_toolchains//:xcode_config
build --@apple_support//xcode:starlark_version_config=@apple_toolchains//:xcode_config

# Build iOS targets for the arm64 simulator by default so the example can be
# launched on a local simulator.
build --ios_multi_cpus=sim_arm64

# Convenience configs for switching Xcodes. Equivalent to passing
# --xcode_version directly. The run options make `bazel run` launchers (for
# example rules_apple's simulator runner) use the hermetic Xcode and pick the
# matching simulator runtime.
build:xcode26 --xcode_version=xcode26_5
run:xcode26 --run_under=@apple_toolchains//:with_developer_dir_xcode26_5
run:xcode26 --ios_simulator_version=26.5

build:xcode27beta2 --xcode_version=xcode27beta2
run:xcode27beta2 --run_under=@apple_toolchains//:with_developer_dir_xcode27beta2
run:xcode27beta2 --ios_simulator_version=27.0
